rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function getUserData(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }
    
    function isOwnerOfBusiness(businessId) {
      let userDoc = exists(/databases/$(database)/documents/users/$(request.auth.uid)) ? get(/databases/$(database)/documents/users/$(request.auth.uid)) : null;
      return isSignedIn() && userDoc != null && userDoc.data.get('businessId', '') == businessId && userDoc.data.get('role', '') == 'OWNER';
    }
    
    function isMemberOfBusiness(businessId) {
      let userDoc = exists(/databases/$(database)/documents/users/$(request.auth.uid)) ? get(/databases/$(database)/documents/users/$(request.auth.uid)) : null;
      return isSignedIn() && userDoc != null && userDoc.data.get('businessId', '') == businessId;
    }

    // --- Validation Blueprints ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'businessId', 'createdAt', 'displayName'])
        && data.keys().size() == 6
        && data.uid == request.auth.uid
        && data.role in ['OWNER', 'EMPLOYEE', 'CUSTOMER', 'ADMIN']
        && data.email is string && data.email.size() < 256
        && data.businessId is string && data.businessId.size() < 128
        && data.displayName is string && data.displayName.size() < 256;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'sku', 'price', 'stockLevel', 'category', 'businessId', 'updatedAt'])
        && data.keys().size() == 7
        && data.name is string && data.name.size() < 256
        && data.price is number && data.price >= 0
        && data.stockLevel is int
        && data.category is string
        && data.businessId is string;
    }

    // --- Rules ---

    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow read: if isSignedIn() && resource != null && isOwnerOfBusiness(resource.data.get('businessId', ''));
      allow create: if isSignedIn() && isValidUser(incoming()) && incoming().uid == request.auth.uid;
      allow update: if isSignedIn() && request.auth.uid == userId 
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'email'])
        && isValidUser(incoming());
    }

    match /businesses/{businessId} {
      allow get: if isMemberOfBusiness(businessId);
      allow create: if isSignedIn() && incoming().ownerId == request.auth.uid;
      allow update: if isOwnerOfBusiness(businessId) && incoming().ownerId == existing().ownerId;
    }

    match /products/{productId} {
      allow read: if resource != null && isMemberOfBusiness(resource.data.get('businessId', ''));
      allow create: if isMemberOfBusiness(incoming().businessId) && isValidProduct(incoming());
      allow update: if isMemberOfBusiness(existing().businessId) 
        && isValidProduct(incoming())
        && incoming().businessId == existing().businessId;
      allow delete: if isOwnerOfBusiness(existing().businessId);
    }

    match /orders/{orderId} {
      allow get: if isSignedIn() && resource != null && (resource.data.get('customerId', '') == request.auth.uid || isMemberOfBusiness(resource.data.get('businessId', '')));
      allow list: if isSignedIn() && (resource.data.get('customerId', '') == request.auth.uid || isMemberOfBusiness(resource.data.get('businessId', '')));
      allow create: if isSignedIn() && incoming().customerId == request.auth.uid;
      allow update: if isMemberOfBusiness(existing().businessId);
    }

    match /transactions/{txId} {
      allow read: if resource != null && isMemberOfBusiness(resource.data.get('businessId', ''));
      allow create: if isMemberOfBusiness(incoming().businessId);
      allow update: if isOwnerOfBusiness(existing().businessId);
    }

    match /production_batches/{batchId} {
      allow read: if resource != null && isMemberOfBusiness(resource.data.get('businessId', ''));
      allow create: if isMemberOfBusiness(incoming().businessId);
      allow update: if isMemberOfBusiness(existing().businessId);
    }
  }
}
